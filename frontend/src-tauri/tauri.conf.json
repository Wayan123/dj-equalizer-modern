{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Modern Audio Enhancer",
  "version": "3.0.0",
  "identifier": "com.modernaudio.enhancer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true
  },
  "app": {
    "windows": [
      {
        "title": "Modern Audio Enhancer",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' asset: https: http://127.0.0.1:18800 blob:; img-src 'self' asset: https: data:; media-src 'self' asset: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'",
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "$TEMP/dj-eq-audio/**"
          ]
        }
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk1RkVGMTlGMTU0MDU1MzQKUldRMFZVQVZuL0grbGQ5WmlRN2psZmhiMnBYWDhySFpJV0p4Vysrek9ZQUlVYytlT2xqRFRIWkoK"
    }
  }
}
